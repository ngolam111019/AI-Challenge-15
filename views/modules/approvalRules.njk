<div class="space-y-6">
    <div class="border-b border-slate-100 pb-4">
        <h2 class="text-xl font-bold text-slate-900">Approval Rules & Routing Matrix</h2>
        <p class="text-sm text-slate-500">Establish automatic approval thresholds and multi-tiered financial escalation roles.</p>
    </div>

    <!-- Auto-approve Threshold -->
    <div class="p-6 rounded-3xl bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 max-w-xl shadow-2xs">
        <div class="flex items-center space-x-3 mb-2">
            <span class="text-2xl">⚡</span>
            <div>
                <h3 class="font-extrabold text-slate-900">Instant Auto-Approval Threshold</h3>
                <p class="text-xs text-slate-500">Claims below this monetary amount bypass manual evaluation entirely.</p>
            </div>
        </div>
        <div class="mt-4 flex items-center space-x-2">
            <span class="text-lg font-extrabold text-slate-400">$</span>
            <input type="number" x-model.number="config.approvalRules.autoApproveThreshold" 
                   @input="if(config.approvalRules.autoApproveThreshold < 0) config.approvalRules.autoApproveThreshold = 0" 
                   min="0" step="500" placeholder="20000"
                   class="w-full px-4 py-2.5 rounded-xl border border-blue-200 font-extrabold text-lg text-blue-700 bg-white focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
            <span class="text-sm font-extrabold text-slate-500">USD</span>
        </div>
        <p class="text-xs text-slate-400 mt-2 italic">Set to 0 to require manual assessment for 100% of claims.</p>
    </div>

    <!-- Tiers Management -->
    <div class="space-y-4 max-w-3xl pt-4">
        <div class="flex justify-between items-center">
            <h3 class="font-extrabold text-slate-800 text-lg">Financial Escalation Tiers</h3>
            <button @click="config.approvalRules.tiers.push({ min: 0, max: 100000, role: 'assessor' })" type="button"
                    class="px-4 py-2 bg-slate-900 text-white rounded-xl text-xs font-bold hover:bg-slate-800 transition shadow-sm flex items-center space-x-1">
                <span>➕ Add Routing Tier</span>
            </button>
        </div>

        <div class="bg-white rounded-3xl border border-slate-200 overflow-hidden shadow-xs">
            <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
                <thead class="bg-slate-50 text-xs font-bold text-slate-500 uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Min Amount ($)</th>
                        <th class="px-6 py-4">Max Amount ($)</th>
                        <th class="px-6 py-4">Required Approver Role</th>
                        <th class="px-6 py-4 text-right">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 font-medium">
                    <template x-for="(tier, idx) in config.approvalRules.tiers" :key="idx">
                        <tr class="hover:bg-slate-50/80 transition">
                            <td class="px-6 py-3.5">
                                <input type="number" x-model.number="tier.min" min="0" step="1000" class="w-full px-3 py-2 rounded-xl border border-slate-300 font-mono font-semibold focus:ring-2 focus:ring-blue-500 text-sm">
                            </td>
                            <td class="px-6 py-3.5">
                                <input type="number" x-model.number="tier.max" min="0" step="1000" class="w-full px-3 py-2 rounded-xl border border-slate-300 font-mono font-semibold focus:ring-2 focus:ring-blue-500 text-sm">
                            </td>
                            <td class="px-6 py-3.5">
                                <select x-model="tier.role" class="w-full px-3 py-2 rounded-xl border border-slate-300 bg-white font-extrabold text-slate-800 focus:ring-2 focus:ring-blue-500 text-sm shadow-2xs">
                                    <option value="assessor">Assessor</option>
                                    <option value="team_lead">Team Lead</option>
                                    <option value="director">Director</option>
                                </select>
                            </td>
                            <td class="px-6 py-3.5 text-right">
                                <button @click="config.approvalRules.tiers.splice(idx, 1)" type="button" class="p-2 text-rose-500 hover:bg-rose-50 rounded-xl transition text-lg" title="Remove tier">
                                    🗑️
                                </button>
                            </td>
                        </tr>
                    </template>
                    <tr x-show="config.approvalRules.tiers.length === 0">
                        <td colspan="4" class="p-8 text-center text-slate-400 italic">No approval tiers configured. All claims above threshold will require fallback assessment.</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
