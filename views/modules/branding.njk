<div class="space-y-6">
    <div class="border-b border-slate-100 pb-4 flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-slate-900">Branding & Visual Identity</h2>
            <p class="text-sm text-slate-500">Custom theme colors and logos for white-label customer portal views.</p>
        </div>
        <div class="w-10 h-10 rounded-xl shadow-md border border-slate-200 flex items-center justify-center font-bold text-white text-xs"
             :style="'background-color: ' + config.branding.primaryColor">
            ✨
        </div>
    </div>

    <div class="space-y-6 max-w-xl">
        <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Portal Display Name</label>
            <input type="text" x-model="config.branding.companyName" placeholder="e.g. SafeGuard Premium Portal"
                   class="w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:outline-none transition text-sm font-semibold">
            <p class="text-xs text-slate-400 mt-1">If left blank, the general Company Name will be used.</p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-bold text-slate-700 mb-1">Primary Brand Color</label>
                <div class="flex items-center space-x-3">
                    <input type="color" x-model="config.branding.primaryColor" class="w-12 h-10 rounded-lg cursor-pointer border border-slate-300">
                    <input type="text" x-model="config.branding.primaryColor" class="w-full px-3 py-2 rounded-xl border border-slate-300 font-mono text-sm uppercase font-bold text-slate-800">
                </div>
                <p class="text-xs text-slate-400 mt-1">Used for buttons, active tabs, and primary accents.</p>
            </div>

            <div>
                <label class="block text-sm font-bold text-slate-700 mb-1">Secondary Brand Color</label>
                <div class="flex items-center space-x-3">
                    <input type="color" x-model="config.branding.secondaryColor" class="w-12 h-10 rounded-lg cursor-pointer border border-slate-300">
                    <input type="text" x-model="config.branding.secondaryColor" class="w-full px-3 py-2 rounded-xl border border-slate-300 font-mono text-sm uppercase font-bold text-slate-800">
                </div>
                <p class="text-xs text-slate-400 mt-1">Used for secondary badges, gradients, and backgrounds.</p>
            </div>
        </div>

        <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Company Logo URL</label>
            <input type="text" x-model="config.branding.logoUrl" placeholder="https://cdn.example.com/logo.png"
                   class="w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:outline-none transition font-mono text-xs">
            <p class="text-xs text-slate-400 mt-1">Provide an absolute URL (HTTPS) to a transparent SVG or PNG logo.</p>
        </div>
    </div>
</div>
