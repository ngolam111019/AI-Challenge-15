<div class="space-y-6" 
     x-init="
        const allIds = ['OUTPATIENT', 'INPATIENT', 'DENTAL', 'MATERNITY', 'OPTICAL'];
        const names = { OUTPATIENT: 'Outpatient', INPATIENT: 'Inpatient', DENTAL: 'Dental', MATERNITY: 'Maternity', OPTICAL: 'Optical' };
        
        allIds.forEach(id => {
            if (!config.claimTypes.some(ct => ct.id === id)) {
                config.claimTypes.push({ id, name: names[id], enabled: false, requiredDocs: [] });
            }
        });

        config.claimTypes.forEach(ct => {
            if (!ct.requiredDocs || !Array.isArray(ct.requiredDocs)) {
                ct.requiredDocs = [];
            } else {
                ct.requiredDocs = ct.requiredDocs.map(doc => {
                    if (typeof doc === 'string') {
                        return { name: doc, required: true };
                    }
                    return doc;
                });
            }
        });
     ">
    <div class="border-b border-slate-100 pb-4 flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-slate-900">Claim Types & Required Documents</h2>
            <p class="text-sm text-slate-500">Configure supported insurance claim types and define dynamic verification documents (mandatory or optional).</p>
        </div>
        <div class="w-10 h-10 rounded-xl bg-blue-50 text-blue-600 font-bold flex items-center justify-center text-lg shadow-inner">
            📄
        </div>
    </div>

    <div class="space-y-6 max-w-4xl">
        <template x-for="(ct, index) in config.claimTypes" :key="ct.id">
            <div class="p-6 rounded-3xl border transition shadow-xs" :class="ct.enabled ? 'bg-slate-50/90 border-blue-300' : 'bg-white border-slate-200 opacity-70'">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-4">
                    <div class="flex items-center space-x-3">
                        <input type="checkbox" x-model="ct.enabled" :id="'ct-toggle-' + index" class="w-5 h-5 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer shadow-2xs">
                        <label :for="'ct-toggle-' + index" class="font-extrabold text-slate-900 text-lg cursor-pointer flex items-center space-x-2">
                            <span x-text="ct.name"></span>
                            <span class="text-xs font-mono font-bold px-2 py-0.5 rounded uppercase shadow-2xs" :class="ct.enabled ? 'bg-blue-600 text-white font-semibold' : 'bg-slate-200 text-slate-600'" x-text="ct.id"></span>
                        </label>
                    </div>
                    <span class="text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wider" :class="ct.enabled ? 'bg-emerald-100 text-emerald-800 border border-emerald-200' : 'bg-slate-100 text-slate-500'" x-text="ct.enabled ? 'Enabled in Portal' : 'Disabled'"></span>
                </div>

                <!-- Document rows -->
                <div x-show="ct.enabled" x-collapse class="space-y-4 pt-4 border-t border-slate-200/80">
                    <div class="flex items-center justify-between">
                        <span class="text-xs font-bold text-slate-600 uppercase tracking-wider flex items-center space-x-1.5">
                            <span>📑 Verification Documents Required for Submission</span>
                        </span>
                        <button @click="ct.requiredDocs.push({ name: '', required: true })" type="button" class="px-3 py-1.5 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold text-xs shadow-md transition flex items-center space-x-1">
                            <span>➕ Add Document</span>
                        </button>
                    </div>

                    <div class="space-y-2.5">
                        <template x-for="(doc, dIdx) in ct.requiredDocs" :key="dIdx">
                            <div class="flex items-center space-x-3 bg-white p-3 rounded-2xl border border-slate-200/80 shadow-2xs">
                                <div class="flex-1 flex items-center space-x-2">
                                    <span class="text-slate-400">📄</span>
                                    <input type="text" x-model="doc.name" placeholder="Document Name (e.g. Hospital Invoice, Prescription)"
                                           class="w-full px-3 py-1.5 rounded-xl bg-slate-50 border border-slate-300 font-semibold text-sm text-slate-800 focus:ring-2 focus:ring-blue-500 focus:outline-none">
                                </div>
                                <div class="flex items-center space-x-2 bg-slate-100 px-3 py-1.5 rounded-xl border border-slate-200">
                                    <input type="checkbox" x-model="doc.required" :id="'req-doc-' + index + '-' + dIdx" class="w-4 h-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer">
                                    <label :for="'req-doc-' + index + '-' + dIdx" class="text-xs font-bold text-slate-700 cursor-pointer select-none">Mandatory</label>
                                </div>
                                <button @click="ct.requiredDocs.splice(dIdx, 1)" type="button" class="w-9 h-9 bg-rose-50 hover:bg-rose-100 text-rose-600 rounded-xl flex items-center justify-center transition border border-rose-200">
                                    🗑️
                                </button>
                            </div>
                        </template>
                        <div x-show="ct.requiredDocs.length === 0" class="p-6 text-center bg-white rounded-2xl border border-dashed border-slate-300 text-slate-400 text-xs italic">
                            No documents added yet. Click "+ Add Document" above to configure required files.
                        </div>
                    </div>
                </div>
            </div>
        </template>
    </div>
</div>
