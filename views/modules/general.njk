<div class="space-y-6">
    <div class="border-b border-slate-100 pb-4">
        <h2 class="text-xl font-bold text-slate-900">General Information</h2>
        <p class="text-sm text-slate-500">Core identification details for this tenant instance.</p>
    </div>

    <div class="space-y-4 max-w-xl">
        <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Company / Tenant Name <span class="text-rose-500">*</span></label>
            <input type="text" x-model="name" @input="generateSlug()" placeholder="e.g. SafeGuard Insurance Corp" 
                   class="w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:outline-none transition font-medium text-slate-900">
            <p class="text-xs text-slate-400 mt-1">Official registered name of the corporate client or branch.</p>
        </div>

        <div>
            <label class="block text-sm font-bold text-slate-700 mb-1">Unique Slug Identifier <span class="text-rose-500">*</span></label>
            <div class="relative">
                <input type="text" x-model="slug" :readonly="mode === 'edit'" :class="mode === 'edit' ? 'bg-slate-100 text-slate-500 cursor-not-allowed font-mono' : 'bg-white font-mono font-semibold'"
                       placeholder="safeguard-insure" class="w-full px-4 py-2.5 rounded-xl border border-slate-300 focus:ring-2 focus:ring-blue-500 focus:outline-none transition text-sm">
                <span x-show="mode === 'edit'" class="absolute right-3.5 top-3 text-slate-400 text-xs font-bold uppercase tracking-wider bg-slate-200/80 px-2 py-0.5 rounded">
                    🔒 Locked (Unique ID)
                </span>
            </div>
            <p class="text-xs text-slate-400 mt-1" x-text="mode === 'create' ? 'Auto-generated from name. Used in API paths /api/v1/claims/:slug' : 'Slugs cannot be modified after creation to prevent API transaction breaks.'"></p>
        </div>
    </div>
</div>
