<div class="space-y-6" x-init="
    const defaultEvents = ['claim_submitted', 'approved', 'rejected', 'payment_sent'];
    if (!config.notifications.events || config.notifications.events.length === 0) {
        config.notifications.events = defaultEvents.map(ev => ({ 
            event: ev, 
            channels: ['email'], 
            channelConfigs: {
                email: { templateType: 'default', customTemplateId: '' },
                sms: { templateType: 'default', customTemplateId: '' },
                webhook: { templateType: 'custom', customTemplateId: 'https://api.erp.local/v1/claims/notify' }
            }
        }));
    } else {
        defaultEvents.forEach(ev => {
            let existing = config.notifications.events.find(e => e.event === ev);
            if (!existing) {
                config.notifications.events.push({ 
                    event: ev, 
                    channels: ['email'], 
                    channelConfigs: {
                        email: { templateType: 'default', customTemplateId: '' },
                        sms: { templateType: 'default', customTemplateId: '' },
                        webhook: { templateType: 'custom', customTemplateId: 'https://api.erp.local/v1/claims/notify' }
                    }
                });
            } else {
                if (!existing.channelConfigs) {
                    existing.channelConfigs = {
                        email: { templateType: 'default', customTemplateId: existing.template || '' },
                        sms: { templateType: 'default', customTemplateId: '' },
                        webhook: { templateType: 'custom', customTemplateId: 'https://api.erp.local/v1/claims/notify' }
                    };
                }
            }
        });
    }
">
    <div class="border-b border-slate-100 pb-4 flex justify-between items-center">
        <div>
            <h2 class="text-xl font-bold text-slate-900">Notification Hooks & Channels</h2>
            <p class="text-sm text-slate-500">Configure multi-channel communication hooks (Email, SMS, Webhook) triggered across claim lifecycle milestones.</p>
        </div>
        <div class="w-10 h-10 rounded-xl bg-purple-50 text-purple-600 font-bold flex items-center justify-center text-lg shadow-inner">
            🔔
        </div>
    </div>

    <div class="space-y-6 max-w-4xl">
        <template x-for="(evt, idx) in config.notifications.events" :key="evt.event">
            <div class="p-6 bg-white rounded-3xl border border-slate-200 shadow-2xs hover:shadow-sm transition">
                <div class="flex items-center space-x-3 pb-4 border-b border-slate-100 mb-4">
                    <span class="text-3xl">
                        <template x-if="evt.event === 'claim_submitted'"><span>📥</span></template>
                        <template x-if="evt.event === 'approved'"><span>🎉</span></template>
                        <template x-if="evt.event === 'rejected'"><span>❌</span></template>
                        <template x-if="evt.event === 'payment_sent'"><span>💸</span></template>
                    </span>
                    <div>
                        <h3 class="font-extrabold text-slate-900 text-lg capitalize" x-text="evt.event.replace('_', ' ')"></h3>
                        <p class="text-xs font-mono font-bold text-slate-400" x-text="'Lifecycle Hook: ' + evt.event"></p>
                    </div>
                </div>

                <!-- Channel Toggles -->
                <div class="space-y-4">
                    <div class="flex flex-wrap gap-6 items-center bg-slate-50 p-4 rounded-2xl border border-slate-100">
                        <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Active Outbound Channels:</span>
                        
                        <label class="flex items-center space-x-2 cursor-pointer">
                            <input type="checkbox" :value="'email'" 
                                   :checked="evt.channels.includes('email')"
                                   @change="$event.target.checked ? evt.channels.push('email') : evt.channels = evt.channels.filter(c => c !== 'email')"
                                   class="w-4 h-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer">
                            <span class="text-sm font-extrabold text-slate-800">📧 Email Hook</span>
                        </label>

                        <label class="flex items-center space-x-2 cursor-pointer">
                            <input type="checkbox" :value="'sms'" 
                                   :checked="evt.channels.includes('sms')"
                                   @change="$event.target.checked ? evt.channels.push('sms') : evt.channels = evt.channels.filter(c => c !== 'sms')"
                                   class="w-4 h-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer">
                            <span class="text-sm font-extrabold text-slate-800">📱 SMS Gateway</span>
                        </label>

                        <label class="flex items-center space-x-2 cursor-pointer">
                            <input type="checkbox" :value="'webhook'" 
                                   :checked="evt.channels.includes('webhook')"
                                   @change="$event.target.checked ? evt.channels.push('webhook') : evt.channels = evt.channels.filter(c => c !== 'webhook')"
                                   class="w-4 h-4 text-blue-600 rounded border-slate-300 focus:ring-blue-500 cursor-pointer">
                            <span class="text-sm font-extrabold text-slate-800">🌐 HTTP Webhook (Gov/ERP)</span>
                        </label>
                    </div>

                    <!-- Per-Channel Template/Endpoint Configuration -->
                    <div class="space-y-3 pt-2">
                        <!-- Email Config -->
                        <div x-show="evt.channels.includes('email')" x-collapse class="bg-blue-50/50 p-4 rounded-2xl border border-blue-100/80 space-y-3">
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-blue-900 uppercase tracking-wider">📧 Email Template Configuration</span>
                            </div>
                            <div class="flex items-center space-x-6">
                                <label class="flex items-center space-x-2 cursor-pointer text-xs font-bold text-slate-700">
                                    <input type="radio" x-model="evt.channelConfigs.email.templateType" value="default" class="text-blue-600 focus:ring-blue-500 cursor-pointer">
                                    <span>Default System Template</span>
                                </label>
                                <label class="flex items-center space-x-2 cursor-pointer text-xs font-bold text-slate-700">
                                    <input type="radio" x-model="evt.channelConfigs.email.templateType" value="custom" class="text-blue-600 focus:ring-blue-500 cursor-pointer">
                                    <span>Custom Template ID</span>
                                </label>
                            </div>
                            <div x-show="evt.channelConfigs.email.templateType === 'custom'" x-collapse>
                                <input type="text" x-model="evt.channelConfigs.email.customTemplateId" placeholder="e.g. sendgrid_tpl_abc123"
                                       class="w-full px-3 py-2 rounded-xl bg-white border border-blue-200 font-mono text-xs font-semibold text-slate-800 focus:ring-2 focus:ring-blue-500 focus:outline-none">
                            </div>
                        </div>

                        <!-- SMS Config -->
                        <div x-show="evt.channels.includes('sms')" x-collapse class="bg-purple-50/50 p-4 rounded-2xl border border-purple-100/80 space-y-3">
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-purple-900 uppercase tracking-wider">📱 SMS Gateway Configuration</span>
                            </div>
                            <div class="flex items-center space-x-6">
                                <label class="flex items-center space-x-2 cursor-pointer text-xs font-bold text-slate-700">
                                    <input type="radio" x-model="evt.channelConfigs.sms.templateType" value="default" class="text-purple-600 focus:ring-purple-500 cursor-pointer">
                                    <span>Default SMS Template</span>
                                </label>
                                <label class="flex items-center space-x-2 cursor-pointer text-xs font-bold text-slate-700">
                                    <input type="radio" x-model="evt.channelConfigs.sms.templateType" value="custom" class="text-purple-600 focus:ring-purple-500 cursor-pointer">
                                    <span>Custom SMS Template ID</span>
                                </label>
                            </div>
                            <div x-show="evt.channelConfigs.sms.templateType === 'custom'" x-collapse>
                                <input type="text" x-model="evt.channelConfigs.sms.customTemplateId" placeholder="e.g. twilio_sms_msg_01"
                                       class="w-full px-3 py-2 rounded-xl bg-white border border-purple-200 font-mono text-xs font-semibold text-slate-800 focus:ring-2 focus:ring-purple-500 focus:outline-none">
                            </div>
                        </div>

                        <!-- Webhook Config -->
                        <div x-show="evt.channels.includes('webhook')" x-collapse class="bg-amber-50/50 p-4 rounded-2xl border border-amber-100/80 space-y-3">
                            <div class="flex items-center justify-between">
                                <span class="text-xs font-bold text-amber-900 uppercase tracking-wider">🌐 HTTP Webhook / ERP Endpoint</span>
                            </div>
                            <div class="flex items-center space-x-6">
                                <label class="flex items-center space-x-2 cursor-pointer text-xs font-bold text-slate-700">
                                    <input type="radio" x-model="evt.channelConfigs.webhook.templateType" value="default" class="text-amber-600 focus:ring-amber-500 cursor-pointer">
                                    <span>Standard JSON Payload</span>
                                </label>
                                <label class="flex items-center space-x-2 cursor-pointer text-xs font-bold text-slate-700">
                                    <input type="radio" x-model="evt.channelConfigs.webhook.templateType" value="custom" class="text-amber-600 focus:ring-amber-500 cursor-pointer">
                                    <span>Custom Endpoint URL</span>
                                </label>
                            </div>
                            <div x-show="evt.channelConfigs.webhook.templateType === 'custom'" x-collapse>
                                <input type="text" x-model="evt.channelConfigs.webhook.customTemplateId" placeholder="https://api.erp.local/v1/claims/notify"
                                       class="w-full px-3 py-2 rounded-xl bg-white border border-amber-200 font-mono text-xs font-semibold text-slate-800 focus:ring-2 focus:ring-amber-500 focus:outline-none">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </template>
    </div>
</div>
