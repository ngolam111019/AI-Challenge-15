{% extends "layout.njk" %}

{% block content %}
<div class="space-y-8" 
     x-data="{
        id1: '{{ id1 | default('') }}',
        id2: '{{ id2 | default('') }}',
        showDiffOnly: false,
        
        swapTenants() {
            if (!this.id1 || !this.id2) return;
            const temp = this.id1;
            this.id1 = this.id2;
            this.id2 = temp;
            this.runDiff();
        },

        runDiff() {
            if (this.id1 && this.id2) {
                htmx.ajax('GET', `/api/tenants/diff-data?id1=${this.id1}&id2=${this.id2}`, { target: '#diff-results' });
            }
        },

        toggleFilter() {
            this.showDiffOnly = !this.showDiffOnly;
            document.querySelectorAll('#diff-results tr').forEach(tr => {
                if (this.showDiffOnly) {
                    if (!tr.classList.contains('is-diff-row')) {
                        tr.classList.add('hidden');
                    }
                } else {
                    tr.classList.remove('hidden');
                }
            });
        }
     }"
     x-init="if (id1 && id2) setTimeout(() => runDiff(), 100)">

    <!-- Top Banner -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center bg-white rounded-3xl p-8 shadow-sm border border-slate-200 gap-4">
        <div>
            <div class="flex items-center space-x-2">
                <a href="/tenants" class="text-sm font-bold text-slate-500 hover:text-blue-600 transition">← All Tenants</a>
                <span class="text-slate-300">/</span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-purple-100 text-purple-800 uppercase tracking-wider">Audit Engine</span>
            </div>
            <h1 class="text-3xl font-extrabold text-slate-900 mt-1">Configuration Diff Audit</h1>
            <p class="text-sm text-slate-500 mt-1">Compare side-by-side rulesets, thresholds, and metadata schemas between any two tenant instances.</p>
        </div>

        <!-- Filter Toggle -->
        <div class="flex items-center space-x-3">
            <button @click="toggleFilter()" 
                    :class="showDiffOnly ? 'bg-amber-500 text-white shadow-md shadow-amber-500/20' : 'bg-slate-100 text-slate-600 hover:bg-slate-200'"
                    class="px-5 py-2.5 rounded-xl font-bold text-sm transition flex items-center space-x-2">
                <span>⚡</span>
                <span x-text="showDiffOnly ? 'Showing Differences Only [≠]' : 'Filter Differences Only [≠]'"></span>
            </button>
        </div>
    </div>

    <!-- Tenant Selectors Toolbar -->
    <div class="p-8 rounded-3xl bg-gradient-to-r from-slate-900 to-slate-800 text-white shadow-xl flex flex-col md:flex-row items-center justify-between gap-6">
        <!-- Tenant A Selection -->
        <div class="w-full md:flex-1">
            <label class="block text-xs font-bold uppercase tracking-wider text-blue-400 mb-2 flex items-center space-x-2">
                <span>🏢 Tenant A (Baseline)</span>
            </label>
            <select x-model="id1" @change="runDiff()" class="w-full px-4 py-3 rounded-xl bg-slate-800/90 border border-slate-700 text-white font-bold text-base focus:ring-2 focus:ring-blue-500 focus:outline-none">
                <option value="">-- Select Baseline Tenant --</option>
                {% for t in tenants %}
                <option value="{{ t.id }}" {% if t.id == id1 %}selected{% endif %}>{{ t.name }} ({{ t.slug }})</option>
                {% endfor %}
            </select>
        </div>

        <!-- Swap Button -->
        <div class="flex items-center justify-center pt-4 md:pt-0">
            <button @click="swapTenants()" title="Swap comparison order" class="w-12 h-12 rounded-2xl bg-slate-700 hover:bg-slate-600 border border-slate-600 text-white flex items-center justify-center text-xl transition shadow-md hover:rotate-180 transform duration-300">
                🔄
            </button>
        </div>

        <!-- Tenant B Selection -->
        <div class="w-full md:flex-1">
            <label class="block text-xs font-bold uppercase tracking-wider text-purple-400 mb-2 flex items-center space-x-2">
                <span>⚖️ Tenant B (Target)</span>
            </label>
            <select x-model="id2" @change="runDiff()" class="w-full px-4 py-3 rounded-xl bg-slate-800/90 border border-slate-700 text-white font-bold text-base focus:ring-2 focus:ring-purple-500 focus:outline-none">
                <option value="">-- Select Comparison Tenant --</option>
                {% for t in tenants %}
                <option value="{{ t.id }}" {% if t.id == id2 %}selected{% endif %}>{{ t.name }} ({{ t.slug }})</option>
                {% endfor %}
            </select>
        </div>
    </div>

    <!-- Comparison Table Grid -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
            <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Side-by-Side Audit Matrix</span>
            <span class="text-xs text-amber-600 font-semibold bg-amber-50 px-2.5 py-1 rounded-md border border-amber-200">
                [≠] Highlight indicates divergent configuration rules
            </span>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-left">
                <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wider">
                    <tr>
                        <th class="w-1/3 px-6 py-4">Configuration Parameter</th>
                        <th class="w-1/3 px-6 py-4 text-blue-600 font-bold">Tenant A (Baseline)</th>
                        <th class="w-1/3 px-6 py-4 text-purple-600 font-bold">Tenant B (Target)</th>
                    </tr>
                </thead>
                <tbody id="diff-results" class="divide-y divide-slate-100 font-medium">
                    <tr>
                        <td colspan="3" class="p-12 text-center text-slate-400">
                            <span class="text-3xl block mb-2">⚖️</span>
                            Please select both Tenant A and Tenant B from the dropdowns above to run the comparison audit.
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
