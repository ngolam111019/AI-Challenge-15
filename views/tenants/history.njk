{% extends "layout.njk" %}

{% block content %}
<div class="space-y-8" 
     x-data="{
        tenantId: {{ tenant.id }},

        confirmRollback(versionId, verNum) {
            Swal.fire({
                title: `Rollback to Version v${verNum}?`,
                html: `You are about to restore the configuration parameters from <b>v${verNum}</b>.<br><br><span class='text-xs text-amber-600 bg-amber-50 px-2.5 py-1 rounded border border-amber-200'>GitHub-style: A new version record will be created. Old logs remain intact.</span>`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f59e0b',
                cancelButtonColor: '#64748b',
                confirmButtonText: 'Yes, execute rollback!'
            }).then(async (result) => {
                if (result.isConfirmed) {
                    try {
                        const res = await fetch(`/api/tenants/${this.tenantId}/rollback`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ targetVersionId: versionId })
                        });
                        if (res.ok) {
                            document.body.dispatchEvent(new Event('refreshHistory'));
                            Toast.fire({ icon: 'success', title: `Rolled back to v${verNum} successfully!` });
                        } else {
                            Toast.fire({ icon: 'error', title: 'Failed to rollback' });
                        }
                    } catch (e) {
                        Toast.fire({ icon: 'error', title: 'Network error during rollback' });
                    }
                }
            });
        }
     }">

    <!-- Top Banner -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center bg-white rounded-3xl p-8 shadow-sm border border-slate-200 gap-4">
        <div>
            <div class="flex items-center space-x-2">
                <a href="/tenants" class="text-sm font-bold text-slate-500 hover:text-blue-600 transition">← All Tenants</a>
                <span class="text-slate-300">/</span>
                <a href="/tenants/{{ tenant.id }}/edit" class="text-sm font-bold text-slate-500 hover:text-blue-600 transition">{{ tenant.name }}</a>
                <span class="text-slate-300">/</span>
                <span class="text-xs font-bold px-2 py-0.5 rounded-md bg-purple-100 text-purple-800 uppercase tracking-wider">Version History</span>
            </div>
            <h1 class="text-3xl font-extrabold text-slate-900 mt-1">Configuration History & Logs</h1>
            <p class="text-sm text-slate-500 mt-1">Immutable audit trail of all parameter changes, SLA updates, and version snapshots.</p>
        </div>

        <div class="flex items-center space-x-3">
            <a href="/tenants/{{ tenant.id }}/edit" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-bold text-sm rounded-xl transition shadow-lg shadow-blue-600/30 flex items-center space-x-2">
                <span>✏️</span>
                <span>Edit Current Version</span>
            </a>
        </div>
    </div>

    <!-- History Table Container -->
    <div class="bg-white rounded-3xl shadow-sm border border-slate-200 overflow-hidden">
        <div class="px-8 py-5 border-b border-slate-100 bg-slate-50/50 flex justify-between items-center">
            <span class="text-xs font-bold text-slate-500 uppercase tracking-wider">Version Timeline</span>
            <span class="text-xs text-slate-400 font-medium">Ranked by version number (descending)</span>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-left">
                <thead class="bg-slate-50 text-xs font-semibold text-slate-500 uppercase tracking-wider">
                    <tr>
                        <th class="px-6 py-4">Version</th>
                        <th class="px-6 py-4">Commit Date</th>
                        <th class="px-6 py-4">Change Note / Commit Message</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody hx-get="/api/tenants/{{ tenant.id }}/history-list" 
                       hx-trigger="load, refreshHistory from:body" 
                       class="divide-y divide-slate-100">
                    <tr>
                        <td colspan="5" class="p-12 text-center text-slate-400 italic">Loading version history...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
